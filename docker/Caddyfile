# Caddyfile for a per-client rawgrowth VPS.
# The $SUBDOMAIN env var is expanded at Caddy startup.
# In local dev the compose file points this at :80 on localhost.

{$CADDY_SITE_ADDRESS:localhost} {
  # tls internal = self-signed cert (no Let's Encrypt round-trip).
  # Use when Cloudflare proxy fronts the host in Full SSL mode:
  # Cloudflare terminates TLS at the edge and re-encrypts to the
  # origin without verifying the origin chain. Avoids LE rate limits
  # when a hostname cycles through repeated deploys.
  tls internal

  encode gzip

  # App — all HTTP traffic
  reverse_proxy app:3000

  # Do not expose postgres or postgrest through the public origin.
}

# Internal-only PostgREST adapter: supabase-js hits /rest/v1/* which
# bare PostgREST doesn't understand. Strip the prefix and forward.
# Only reachable inside the docker network on port 3100.
:3100 {
  route /rest/v1/* {
    uri strip_prefix /rest/v1
    reverse_proxy postgrest:3000
  }
  route {
    reverse_proxy postgrest:3000
  }
}
