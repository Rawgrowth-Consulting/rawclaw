{
  "name": "rawgrowth-aios",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:unit": "tsx --test tests/unit/*.spec.ts",
    "dev": "next dev",
    "dev:bootstrap": "./scripts/dev-bootstrap.sh",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:db:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v && ./scripts/dev-bootstrap.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "self-hosted:bootstrap": "./scripts/bootstrap.sh",
    "self-hosted:migrate": "tsx scripts/migrate.ts",
    "self-hosted:jwt": "tsx scripts/gen-jwt.ts",
    "self-hosted:up": "docker compose up --build",
    "self-hosted:down": "docker compose down",
    "self-hosted:logs": "docker compose logs -f app",
    "client:provision": "./scripts/provision-vps.sh",
    "client:update": "./scripts/update-vps.sh",
    "client:cc-install": "./scripts/cc-install.sh",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@anthropic-ai/sdk": "^0.39.0",
    "@anush008/tokenizers-linux-x64-gnu": "^0.6.0",
