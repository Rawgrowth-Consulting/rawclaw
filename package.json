    "fastembed": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.0",
    "reactflow": "^11.11.4",
    "resend": "^6.12.0",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "swr": "^2.4.1",
