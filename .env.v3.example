# ──────────────────────────────────────────────────────────
# Rawgrowth AIOS v3 — per-client VPS template.
#
# Copy to .env on the VPS, fill the blanks, run docker compose -f
# docker-compose.v3.yml up -d. Migrations apply on boot via entrypoint.
#
# Three categories below: SUPABASE (shared, Rawgrowth-owned project),
# THIS VPS (unique per client install), and OPTIONAL (integrations).
# ──────────────────────────────────────────────────────────

# ────── DEPLOY MODE ──────
# 'v3' selects shared Supabase + Path A Claude CLI defaults across the app.
# 'self_hosted' is the legacy per-VPS Postgres mode kept for v2 clients.
DEPLOY_MODE=v3

# ────── SUPABASE (shared across all v3 clients) ──────
# Created once under the Rawgrowth Supabase org. Same values on every VPS.
# wire-supabase.sh writes these for you when you run it from a workstation.
DATABASE_URL=postgres://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ────── THIS VPS (unique per client install) ──────
# Fully-qualified domain Caddy serves on. Issues TLS via Let's Encrypt.
CADDY_SITE_ADDRESS=clientslug.rawgrowth.ai
NEXTAUTH_URL=https://clientslug.rawgrowth.ai

# Rotated per VPS at provisioning time. Used for app-level secret-at-rest
# encryption. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
JWT_SECRET=

# Bearer for /api/cron/* endpoints (schedule-tick, claude-token).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Heartbeat tick interval in seconds. Brief §9.6 default 10 min (600).
# Lower for testing (e.g. 60 = once a minute). Honoured by
# scripts/provision-vps.sh when wiring rawgrowth-tick.timer.
HEARTBEAT_INTERVAL_SEC=600

# First-boot org seed. Set once, ignored on subsequent boots.
SEED_ORG_NAME=Client Co
SEED_ORG_SLUG=clientslug
SEED_ADMIN_EMAIL=admin@clientco.com
SEED_ADMIN_NAME=Client Admin

# ────── ANTHROPIC (Path A primary + Path B fallback) ──────
# Path A (Claude Code CLI under client's Max OAuth) is set up by
# scripts/cc-install.sh on the VPS host, NOT via this env var. The
# four vars below select Path A for every Claude call site.
RUNTIME_PATH=cli
CLAUDE_CLI_PATH=/home/rawclaw/.local/bin/claude
LLM_PROVIDER=anthropic-cli
ONBOARDING_LLM_PROVIDER=anthropic-cli
EXECUTOR_LLM_PROVIDER=anthropic-cli
BRAND_VOICE_LLM_PROVIDER=anthropic-cli

# Path B (Anthropic SDK fallback) uses the workspace API key below.
# Optional at boot; required only when LLM_PROVIDER is flipped to
# 'anthropic-api' or as a per-call-site override.
ANTHROPIC_API_KEY=

# ────── OPENAI (optional fallback) ──────
# Only needed when a per-call-site provider is flipped to 'openai' (the
# onboarding flow accepts either Anthropic or OpenAI via the multi-
# provider abstraction in src/lib/llm/provider.ts). Path A defaults
# above route every call through Claude CLI, so this can stay empty
# for the standard v3 install.
OPENAI_API_KEY=

# ────── EMBEDDING PROVIDER (optional override) ──────
# Default 'fastembed' — runs BAAI/bge-small-en-v1.5 locally inside the
# app process via fastembed-js (ONNX, ~250MB RSS). Zero API key, fits
# CX22, MIT-licensed. 384d zero-padded to the 1536d pgvector column.
# Other providers stay available for ops who want them:
#   EMBEDDING_PROVIDER=fastembed (default, no key)
#   EMBEDDING_PROVIDER=openai    (requires OPENAI_API_KEY)
#   EMBEDDING_PROVIDER=voyage    (requires VOYAGE_API_KEY, 1024d→1536d)
# Do not mix providers in one corpus; flip per-VPS and backfill if needed.
EMBEDDING_PROVIDER=fastembed
VOYAGE_API_KEY=

# ────── EMAIL (invites + magic-link + password reset) ──────
RESEND_API_KEY=
EMAIL_FROM=noreply@rawgrowth.ai

# ────── NANGO (third-party integrations) ──────
# Optional for the trial. Required if you turn on Gmail/Slack/Notion/etc.
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_WEBHOOK_SECRET=
