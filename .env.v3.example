# ──────────────────────────────────────────────────────────
# Rawgrowth AIOS v3 — per-client VPS template.
#
# Copy to .env on the VPS, fill the blanks, run docker compose -f
# docker-compose.v3.yml up -d. Migrations apply on boot via entrypoint.
#
# Three categories below: SUPABASE (shared, Rawgrowth-owned project),
# THIS VPS (unique per client install), and OPTIONAL (integrations).
# ──────────────────────────────────────────────────────────

# ────── SUPABASE (shared across all v3 clients) ──────
# Created once under the Rawgrowth Supabase org. Same values on every VPS.
DATABASE_URL=postgres://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ────── THIS VPS (unique per client install) ──────
# Fully-qualified domain Caddy serves on. Issues TLS via Let's Encrypt.
CADDY_SITE_ADDRESS=clientslug.rawgrowth.ai
NEXTAUTH_URL=https://clientslug.rawgrowth.ai

# Rotated per VPS at provisioning time. Used for app-level secret-at-rest
# encryption. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
JWT_SECRET=

# Bearer for /api/cron/* endpoints (schedule-tick, claude-token).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# First-boot org seed. Set once, ignored on subsequent boots.
SEED_ORG_NAME=Client Co
SEED_ORG_SLUG=clientslug
SEED_ADMIN_EMAIL=admin@clientco.com
SEED_ADMIN_NAME=Client Admin

# ────── ANTHROPIC (Path A primary + Path B fallback) ──────
# Path A (Claude Code CLI under client's Max OAuth) is set up by
# scripts/cc-install.sh on the VPS host, NOT via this env var.
#
# Path B (Anthropic SDK fallback) uses the workspace API key below.
# Optional at boot; required the first time the runtime selector
# flips from CLI to SDK.
ANTHROPIC_API_KEY=

# ────── OPENAI (onboarding chat + embeddings) ──────
# Required for the AI-assisted onboarding flow (gpt-4o agentic loop)
# and per-agent file RAG (text-embedding-3-large).
OPENAI_API_KEY=

# ────── EMAIL (invites + magic-link + password reset) ──────
RESEND_API_KEY=
EMAIL_FROM=noreply@rawgrowth.ai

# ────── NANGO (third-party integrations) ──────
# Optional for the trial. Required if you turn on Gmail/Slack/Notion/etc.
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_WEBHOOK_SECRET=
